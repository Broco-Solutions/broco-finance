{
  "name": "broco-finance",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint .",
    "postinstall": "prisma generate",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "data:extract": "tsx scripts/extract-finance-xlsx.ts",
    "db:seed:test": "NODE_ENV=test ALLOW_DESTRUCTIVE_TEST_DB=true DATABASE_URL=postgresql://mock:mock@localhost:9999/broco_finance_prod DATABASE_URL_TEST=postgresql://broco_test:broco_test@localhost:5434/broco_finance_test tsx prisma/seed.ts",
    "db:initialize:production": "tsx scripts/initialize-production.ts",
    "test": "vitest run",
    "test:unit": "vitest run --dir tests/unit",
    "test:integration": "test -n \"$DATABASE_URL_TEST\" || (echo \"DATABASE_URL_TEST no esta definida\" && exit 1); vitest run tests/integration/smoke-db.test.ts && DATABASE_URL=\"$DATABASE_URL_TEST\" vitest run tests/integration/clients-projects.test.ts tests/integration/incomes.test.ts tests/integration/expenses-dashboard.test.ts tests/integration/reconciliation.test.ts",
    "test:db:up": "docker compose -f docker-compose.test.yml up -d",
    "test:db:down": "docker compose -f docker-compose.test.yml down",
    "test:db:status": "docker compose -f docker-compose.test.yml ps"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@prisma/client": "^6.19.2",
    "bubblewrap": "^0.2.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.577.0",
    "next": "^14.2.35",
    "prisma": "^6.19.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^3.8.0",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^20.19.37",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "autoprefixer": "^10.4.27",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.35",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.10",
    "xlsx": "^0.18.5"
  }
}
